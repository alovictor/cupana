; exemplo.casm
MOV R1 #F000  ; Endereço do registrador de dados do terminal
MOV R2 $90
MOV R1* R2

; Usando MOV Mem, Reg (Opcode 0x14) - MOV (endereço literal), Reg
MOV R2 $72
MOV #F000 R2  ; Escreve 'H' para o endereço 0xF000

MOV R2 $101
MOV #F000 R2

MOV R2 $108
MOV #F000 R2
MOV #F000 R2 ; 'l' novamente

MOV R2 $111
MOV #F000 R2

HLT