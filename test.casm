!cr #F000

string: .word "Hello World!"

reset:
    MOV !cr $72  ; H
    MOV !cr $101 ; E
    MOV !cr $108 ; L
    MOV !cr $108 ; L
    MOV !cr $111 ; O
    MOV !cr $32  ; 
    MOV !cr $87  ; W
    MOV !cr $111 ; O
    MOV !cr $114 ; R
    MOV !cr $108 ; L
    MOV !cr $100 ; D
    MOV !cr $33  ; !
    MOV r0 $33
    jsb print_char
    HLT

print_char:
    mov #F000 r0
    rsb

nmi:
irq:
    MOV r0 $33
    jsb print_char
    rsi

.org #7FFA
.word nmi
.word reset
.word irq